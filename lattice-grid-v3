<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lattice Grid v3 — Trading Dashboard</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap');
:root{--bg:#080c0f;--bg2:#0d1318;--bg3:#111920;--border:#1a2530;--green:#00e676;--red:#ff3d57;--blue:#2196f3;--amber:#ffb300;--muted:#4a6070;--text:#c8d8e0;--text2:#7a9aaa;}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--bg);color:var(--text);font-family:'Space Grotesk',sans-serif;min-height:100vh;padding-bottom:40px;}
header{background:var(--bg2);border-bottom:1px solid var(--border);padding:15px 22px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;flex-wrap:wrap;gap:10px;}
.logo{display:flex;align-items:center;gap:12px;}
.logo-icon{width:38px;height:38px;border:2px solid var(--green);display:grid;place-items:center;font-size:16px;color:var(--green);}
.logo h1{font-family:'Space Mono',monospace;font-size:14px;font-weight:700;letter-spacing:3px;color:#fff;}
.logo p{font-size:9px;letter-spacing:2px;color:var(--text2);}
.hright{display:flex;align-items:center;gap:10px;}
.modebadge{font-family:'Space Mono',monospace;font-size:11px;letter-spacing:1px;padding:6px 14px;border:1px solid var(--border);}
.modebadge.paper{color:var(--amber);border-color:rgba(255,179,0,.4);}
.modebadge.real{color:var(--red);border-color:rgba(255,61,87,.4);}
.spill{display:flex;align-items:center;gap:7px;padding:5px 13px;border:1px solid var(--border);font-family:'Space Mono',monospace;font-size:11px;letter-spacing:1px;}
.sdot{width:8px;height:8px;border-radius:50%;background:var(--muted);}
.sdot.live{background:var(--green);animation:blink 1.5s infinite;}
.sdot.err{background:var(--red);}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
.fixbar{background:rgba(0,230,118,.06);border-bottom:1px solid rgba(0,230,118,.2);padding:9px 22px;font-family:'Space Mono',monospace;font-size:9.5px;color:var(--text2);letter-spacing:.3px;}
.main{padding:18px 22px;display:grid;gap:14px;}
.stat-row{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;}
@media(max-width:800px){.stat-row{grid-template-columns:repeat(3,1fr);}}
@media(max-width:500px){.stat-row{grid-template-columns:repeat(2,1fr);}}
.sc{background:var(--bg2);border:1px solid var(--border);padding:16px;}
.sc-lbl{font-size:9px;letter-spacing:2px;color:var(--text2);margin-bottom:6px;}
.sc-val{font-family:'Space Mono',monospace;font-size:20px;font-weight:700;color:#fff;}
.sc-val.g{color:var(--green);}.sc-val.r{color:var(--red);}
.sc-sub{font-size:10px;color:var(--text2);margin-top:3px;}
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
@media(max-width:800px){.two-col{grid-template-columns:1fr;}}
.panel{background:var(--bg2);border:1px solid var(--border);}
.panel-hdr{padding:11px 15px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.ptitle{font-family:'Space Mono',monospace;font-size:10px;letter-spacing:2px;color:var(--text2);}
.pbadge{font-family:'Space Mono',monospace;font-size:9px;padding:2px 7px;background:var(--bg3);border:1px solid var(--border);}
.pbadge.g{color:var(--green);border-color:rgba(0,230,118,.3);}
.pbadge.r{color:var(--red);border-color:rgba(255,61,87,.3);}
.otbl{width:100%;font-size:11px;border-collapse:collapse;}
.otbl th{font-family:'Space Mono',monospace;font-size:9px;letter-spacing:1px;color:var(--text2);padding:7px 9px;text-align:left;border-bottom:1px solid var(--border);}
.otbl td{padding:7px 9px;border-bottom:1px solid rgba(26,37,48,.5);font-family:'Space Mono',monospace;}
.otbl tr:last-child td{border:none;}
.otbl tr.br td{color:var(--green);}
.otbl tr.sr td{color:var(--red);}
.empty-row td{color:var(--muted)!important;font-size:10px;}
.bal-item{padding:12px 15px;border-bottom:1px solid rgba(26,37,48,.5);}
.bal-item:last-child{border:none;}
.bal-row{display:flex;justify-content:space-between;font-size:11px;}
.bsym{font-family:'Space Mono',monospace;color:var(--text2);letter-spacing:1px;}
.bval{font-family:'Space Mono',monospace;color:#fff;font-weight:700;}
.bsub{font-size:9px;color:var(--text2);margin-top:3px;}
.log-wrap{max-height:280px;overflow-y:auto;display:flex;flex-direction:column;gap:3px;padding:7px;}
.le{display:flex;gap:7px;font-size:10px;padding:5px 7px;background:var(--bg3);}
.le.buy{border-left:2px solid var(--green);}
.le.sell{border-left:2px solid var(--red);}
.le.info{border-left:2px solid var(--blue);}
.le.err{border-left:2px solid var(--red);opacity:.7;}
.lt{font-family:'Space Mono',monospace;color:var(--muted);white-space:nowrap;font-size:9px;padding-top:1px;}
.lm{color:var(--text);flex:1;line-height:1.4;}
footer{padding:13px 22px;border-top:1px solid var(--border);display:flex;justify-content:space-between;font-size:10px;color:var(--muted);font-family:'Space Mono',monospace;margin-top:6px;}
::-webkit-scrollbar{width:4px;height:4px;}
::-webkit-scrollbar-track{background:var(--bg);}
::-webkit-scrollbar-thumb{background:var(--border);}
</style>
</head>
<body>

<header>
  <div class="logo">
    <div class="logo-icon">◈</div>
    <div>
      <h1>LATTICE GRID V3</h1>
      <p>SELF-TUNING GRID BOT — CRYPTO.COM</p>
    </div>
  </div>
  <div class="hright">
    <div class="modebadge paper" id="modeBadge">— MODE —</div>
    <div class="spill"><div class="sdot" id="sDot"></div><span id="sTxt">CONNECTING</span></div>
  </div>
</header>

<div class="fixbar">✓ order_id validation · ✓ stuck-order eviction · ✓ fee-aware P&amp;L · ✓ oversell protection · ✓ cash-reservation fix · ✓ self-tuning profit margin per pair</div>

<div class="main">

  <div class="stat-row">
    <div class="sc">
      <div class="sc-lbl">TOTAL P&amp;L</div>
      <div class="sc-val" id="pnl">$0.00</div>
      <div class="sc-sub" id="pnlPct">+0.00% since start</div>
    </div>
    <div class="sc">
      <div class="sc-lbl">CASH</div>
      <div class="sc-val g" id="cashBal">—</div>
      <div class="sc-sub">Available</div>
    </div>
    <div class="sc">
      <div class="sc-lbl">TRADES</div>
      <div class="sc-val" id="tradeCount">0</div>
      <div class="sc-sub" id="winSub">0 wins</div>
    </div>
    <div class="sc">
      <div class="sc-lbl">WIN RATE</div>
      <div class="sc-val" id="winRate">0%</div>
      <div class="sc-sub">of completed trades</div>
    </div>
    <div class="sc">
      <div class="sc-lbl">STARTED</div>
      <div class="sc-val" id="startedAt" style="font-size:13px">—</div>
      <div class="sc-sub">bot launch time</div>
    </div>
  </div>

  <div class="two-col">
    <div class="panel">
      <div class="panel-hdr"><span class="ptitle">// HOLDINGS</span></div>
      <div id="assetsWrap"></div>
    </div>
    <div class="panel">
      <div class="panel-hdr"><span class="ptitle">// MEMORY — SELF-TUNED SELL MARGIN</span></div>
      <div id="memWrap"></div>
    </div>
  </div>

  <div class="panel">
    <div class="panel-hdr">
      <span class="ptitle">// OPEN ORDERS — ALL PAIRS</span>
      <span class="pbadge g" id="openBadge">0 ACTIVE</span>
    </div>
    <table class="otbl">
      <thead><tr><th>PAIR</th><th>SIDE</th><th>PRICE</th><th>QTY</th></tr></thead>
      <tbody id="ordersBody"><tr class="empty-row"><td colspan="4" style="padding:12px 9px">No open orders</td></tr></tbody>
    </table>
  </div>

  <div class="panel">
    <div class="panel-hdr">
      <span class="ptitle">// RECENT TRADES</span>
      <span class="pbadge g" id="tradesBadge">0</span>
    </div>
    <table class="otbl">
      <thead><tr><th>PAIR</th><th>PRICE</th><th>QTY</th><th>PROFIT</th></tr></thead>
      <tbody id="tradesBody"><tr class="empty-row"><td colspan="4" style="padding:12px 9px">No trades yet</td></tr></tbody>
    </table>
  </div>

  <div class="panel">
    <div class="panel-hdr">
      <span class="ptitle">// LIVE ACTIVITY LOG</span>
      <span class="pbadge" id="logBadge">0 ENTRIES</span>
    </div>
    <div class="log-wrap" id="logFeed">
      <div class="le info"><span class="lt">--:--:--</span><span class="lm">Connecting to Lattice Grid v3...</span></div>
    </div>
  </div>

</div>

<footer>
  <span>LATTICE COLLECTIVE © 2026 — CLOUDFLARE WORKERS 24/7</span>
  <span>UPDATED <span id="updTime">—</span></span>
</footer>

<script>
// Update this if your Worker's actual subdomain differs
const W = 'https://lattice-grid-v3.latticecollective-io.workers.dev';
const START_CAPITAL = 500;
let failCount = 0;
let prices = { BTC_USDT: 0, ETH_USDT: 0, SOL_USDT: 0 };

function setStatus(cls, txt) {
  document.getElementById('sDot').className = 'sdot ' + cls;
  document.getElementById('sTxt').textContent = txt;
}
function safe(fn) { try { fn(); } catch (e) { console.warn('Render err:', e); } }
function fmtSigned(n) { return (n >= 0 ? '+$' : '-$') + Math.abs(n).toFixed(2); }

async function fetchPrices() {
  for (const sym of Object.keys(prices)) {
    try {
      const r = await fetch(`https://api.crypto.com/exchange/v1/public/get-tickers?instrument_name=${sym}`);
      const j = await r.json();
      const p = parseFloat(j?.result?.data?.[0]?.a || j?.result?.data?.[0]?.k || 0);
      if (p) prices[sym] = p;
    } catch (e) {}
  }
}

async function poll() {
  try {
    const res = await fetch(`${W}/grid-status`, { cache: 'no-store' });
    if (!res.ok) throw new Error('HTTP ' + res.status);
    const d = await res.json();
    failCount = 0;
    setStatus('live', 'LIVE');
    render(d);
  } catch (e) {
    failCount++;
    if (failCount >= 3) setStatus('err', 'OFFLINE');
  }
}

function render(d) {
  const g = d.grid || {};
  const logs = d.logs || [];

  safe(() => {
    const badge = document.getElementById('modeBadge');
    const isPaper = (g.mode || 'paper') === 'paper';
    badge.textContent = isPaper ? 'PAPER MODE — SIMULATED' : 'REAL CAPITAL — LIVE';
    badge.className = 'modebadge ' + (isPaper ? 'paper' : 'real');
  });

  safe(() => {
    document.getElementById('startedAt').textContent = g.startedAt ? new Date(g.startedAt).toLocaleString() : '—';
  });

  safe(() => {
    const cash = g.cash || 0;
    const cashEl = document.getElementById('cashBal');
    cashEl.textContent = (cash >= 0 ? '$' : '-$') + Math.abs(cash).toFixed(2);
    cashEl.className = 'sc-val ' + (cash >= 0 ? 'g' : 'r');

    let equity = cash;
    const assets = g.assets || {};
    Object.keys(assets).forEach(sym => { equity += (assets[sym].qty || 0) * (prices[sym] || 0); });

    const pnl = equity - START_CAPITAL;
    const pct = (pnl / START_CAPITAL) * 100;
    const pnlEl = document.getElementById('pnl');
    pnlEl.textContent = fmtSigned(pnl);
    pnlEl.className = 'sc-val ' + (pnl >= 0 ? 'g' : 'r');
    document.getElementById('pnlPct').textContent = (pct >= 0 ? '+' : '') + pct.toFixed(2) + '% since start';
  });

  safe(() => {
    document.getElementById('tradeCount').textContent = g.tradeCount || 0;
    document.getElementById('winSub').textContent = (g.winCount || 0) + ' wins';
    document.getElementById('winRate').textContent = (g.winRate || 0) + '%';
  });

  safe(() => {
    const assets = g.assets || {};
    const wrap = document.getElementById('assetsWrap');
    wrap.innerHTML = Object.keys(assets).map(sym => {
      const a = assets[sym];
      const price = prices[sym] || 0;
      const val = (a.qty || 0) * price;
      return `<div class="bal-item">
        <div class="bal-row"><span class="bsym">${sym.replace('_USDT','')}</span><span class="bval">${(a.qty||0).toFixed(6)}</span></div>
        <div class="bsub">avg cost $${(a.avgCost||0).toFixed(2)} — value ≈ $${val.toFixed(2)}</div>
      </div>`;
    }).join('') || '<div class="bal-item"><div class="bsub">No data yet</div></div>';
  });

  safe(() => {
    const memory = g.memory || {};
    const wrap = document.getElementById('memWrap');
    wrap.innerHTML = Object.keys(memory).map(sym => {
      const m = memory[sym];
      const n = (m.pastProfitPct || []).length;
      return `<div class="bal-item">
        <div class="bal-row"><span class="bsym">${sym.replace('_USDT','')}</span><span class="bval">${((m.tunedMargin||0)*100).toFixed(2)}%</span></div>
        <div class="bsub">margin required above cost — tuned from ${n} past trade${n===1?'':'s'}</div>
      </div>`;
    }).join('') || '<div class="bal-item"><div class="bsub">No data yet</div></div>';
  });

  safe(() => {
    const openOrders = g.openOrders || {};
    let all = [];
    Object.keys(openOrders).forEach(sym => (openOrders[sym] || []).forEach(o => all.push({ ...o, pair: sym })));
    document.getElementById('openBadge').textContent = all.length + ' ACTIVE';
    document.getElementById('openBadge').className = 'pbadge ' + (all.length > 30 ? 'r' : 'g');
    const ob = document.getElementById('ordersBody');
    ob.innerHTML = all.length ? all.map(o => `<tr class="${o.side === 'BUY' ? 'br' : 'sr'}">
      <td>${o.pair.replace('_USDT','')}</td><td>${o.side}</td>
      <td>$${(o.price||0).toFixed(2)}</td><td>${(o.qty||0).toFixed(6)}</td>
    </tr>`).join('') : '<tr class="empty-row"><td colspan="4" style="padding:12px 9px">No open orders</td></tr>';
  });

  safe(() => {
    const trades = g.trades || [];
    document.getElementById('tradesBadge').textContent = trades.length;
    const tb = document.getElementById('tradesBody');
    tb.innerHTML = trades.length ? trades.map(t => `<tr class="${(t.profit||0) >= 0 ? 'br' : 'sr'}">
      <td>${(t.symbol||'—').replace('_USDT','')}</td>
      <td>$${(t.price||0).toFixed(2)}</td>
      <td>${(t.qty||0).toFixed(6)}</td>
      <td>${fmtSigned(t.profit||0)}</td>
    </tr>`).join('') : '<tr class="empty-row"><td colspan="4" style="padding:12px 9px">No trades yet</td></tr>';
  });

  safe(() => {
    document.getElementById('logBadge').textContent = logs.length + ' ENTRIES';
    if (logs.length) {
      document.getElementById('logFeed').innerHTML = [...logs].reverse().slice(0, 60).map(l => {
        const msg = l.msg || '';
        const type = msg.includes('BUY') ? 'buy' : msg.includes('SELL') ? 'sell' : (msg.includes('failed') || msg.includes('error')) ? 'err' : 'info';
        const time = l.ts ? new Date(l.ts).toLocaleTimeString() : '--:--:--';
        return `<div class="le ${type}"><span class="lt">${time}</span><span class="lm">${msg}</span></div>`;
      }).join('');
    }
    document.getElementById('updTime').textContent = new Date().toLocaleTimeString();
  });
}

async function tick() { await fetchPrices(); await poll(); }
tick();
setInterval(tick, 3000);
</script>
</body>
</html>
